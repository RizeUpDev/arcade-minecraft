{
    "name": "minecraft-arcade",
    "version": "1.0.0",
    "description": "A full-featured Minecraft extension for MakeCode Arcade with worlds, blocks, players, mobs, items, redstone, crafting, and events.",
    "license": "MIT",
    "dependencies": {
        "device": "*"
    },
    "files": [
        "mc-enums.ts",
        "mc-world.ts",
        "mc-blocks.ts",
        "mc-player.ts",
        "mc-mobs.ts",
        "mc-items.ts",
        "mc-redstone.ts",
        "mc-crafting.ts",
        "mc-events.ts",
        "mc-ui.ts",
        "mc-commands.ts"
    ],
    "testFiles": [
        "test.ts"
    ],
    "public": true,
    "supportedTargets": ["arcade"],
    "targetVersions": {
        "target": ">=1.3.30"
    },
    "yotta": {
        "config": {
            "MINECRAFT_ARCADE_EXTENSION": 1
        }
    }
}
